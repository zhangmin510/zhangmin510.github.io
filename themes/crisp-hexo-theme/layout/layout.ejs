<!doctype html>
<html lang="en">
    <head>
		<%
		  var title = page.title;

		  if (is_archive()){
		    title = 'Archives';

		    if (is_month()){
		      title += ': ' + page.year + '/' + page.month;
		    } else if (is_year()){
		      title += ': ' + page.year;
		    }
		  } else if (is_category()){
		    title = 'Category: ' + page.category;
		  } else if (is_tag()){
		    title = 'Tag: ' + page.tag;
		  }
		%>
        <meta http-equiv="Content-Type" content="text/html" charset="UTF-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
        <meta name="description" content="<%- config.description %>">
        <link rel="shortcut icon" href="<%- theme.logo %>"/>
        <link rel="alternate" type="application/rss+xml" title="<%- config.author %>" href="<%- theme.feed %>">
        <link rel="canonical" href="http://www.zhangmin.name/">

        <title><% if (title){ %><%= title %> | <% } %><%= config.title %></title>
        <meta name="description" content="{{meta_description}}">

        <link href="//libs.baidu.com/fontawesome/4.0.3/css/font-awesome.min.css" rel="stylesheet">
        <link rel="stylesheet" type="text/css" href="<%- config.root %>styles/crisp.css">
        <meta name="HandheldFriendly" content="True" />
        <meta name="MobileOptimized" content="320" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <!-- HTML5 shim and Respond.js IE8 support of HTML5 elements and media queries -->
        <!--[if lt IE 9]>
        <script src="https://oss.maxcdn.com/libs/html5shiv/3.7.0/html5shiv.js"></script>
        <script src="https://oss.maxcdn.com/libs/respond.js/1.4.2/respond.min.js"></script>
        <![endif]-->

    </head>
    <% if (typeof page.title == 'undefined') { %>
		<body class="home-template">
	<% } else { %>
		<body class="post-template">
	<% } %>

        <header id="header">
            <% if (theme.logo) { %><a id="logo" href="https://zhangmin.name"><img src="<%- theme.logo %>" alt="<%- config.title%>" /></a><% } %>
            <h1><a href="<%- config.root %>"><%- config.author %></a></h1>
            <p><%- config.subtitle %></p>
            <%- partial('_partial/follow') %>
        </header>

        <main id="content">
        <%- body %>
        </main>
        <footer id="footer">
            <section id="footer-message">&copy; <%= date(new Date(), 'YYYY') %> <%= config.author || config.title %>. All rights reserved. Powered by <a href="http://hexo.io/" target="_blank">Hexo</a>. <a href="https://github.com/guolin/crisp-hexo-theme" target="_blank">crisp</a> theme customized by <a href="http://zhangmin.name" target="_blank">ZhangMin.name</a>.</section>
        </footer>
    </body>
</html>
